{
  "name": "saramonse",
  "version": "1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "generate:menus": "tsx scripts/generate-menu-pdfs.ts",
    "build": "npm run generate:menus && astro build",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy",
    "worker:dev": "npm run build && wrangler dev",
    "build:watch": "nodemon -q --watch src --watch public --watch astro.config.mjs --ignore public/assets/*.pdf --ext astro,css,mjs,js,ts,tsx,json --exec \"npm run build\"",
    "worker:api": "wrangler dev --live-reload",
    "worker:watch": "concurrently -k -n site,wrangler -c cyan,magenta \"npm run build:watch\" \"wait-on dist/index.html && wrangler dev --live-reload\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4",
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@react-pdf/renderer": "^4.3.2",
    "@splidejs/splide": "^4.1.4",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^5.18.1",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
