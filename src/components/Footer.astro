---
import navigation from '../data/navigation.js';

interface Props {
  footerTheme?: 'light' | 'dark';
  isHomepage?: boolean;
}

const { footerTheme = 'light', isHomepage = false } = Astro.props;

const currentYear = new Date().getFullYear();

const ftBg = footerTheme === 'dark' ? 'bg-black' : 'bg-white';
const ftText = footerTheme === 'dark' ? 'text-white' : 'text-gray-900';
const ftTextMuted = footerTheme === 'dark' ? 'text-white/70' : 'text-gray-700';
const ftTextHover = footerTheme === 'dark' ? 'hover:text-white' : 'hover:text-gray-900';
const ftSocial =
  footerTheme === 'dark' ? 'text-white hover:text-white/70' : 'text-gray-900 hover:text-gray-600';
const ftBottomBorder = footerTheme === 'dark' ? 'border-white/20' : 'border-gray-200';
const ftBottomText = footerTheme === 'dark' ? 'text-white/60' : 'text-gray-600';
const ftBottomHover = footerTheme === 'dark' ? 'hover:text-white' : 'hover:text-gray-900';
/** Nested footer links: lighter weight + softer tone vs primary row (Home / Services label). */
const ftNavChild =
  footerTheme === 'dark'
    ? 'text-white/65 font-light text-sm tracking-wide transition-colors hover:text-white'
    : 'text-gray-500 font-light text-sm tracking-wide transition-colors hover:text-gray-900';
const ftNavChildRule = footerTheme === 'dark' ? 'border-white/15' : 'border-gray-200/90';
---

<footer>
  {
    isHomepage ? (
      <div class="bg-black text-white py-16 sm:py-20 px-6 sm:px-8">
        <div class="max-w-7xl mx-auto">
          <h2
            class="text-3xl sm:text-4xl lg:text-5xl font-light mb-10 sm:mb-12 tracking-wide text-left"
            style="font-family: 'Cormorant Garamond', 'Georgia', serif;"
          >
            Let's Talk
          </h2>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start font-sans text-white/90">
            <div class="space-y-5 sm:space-y-6 min-w-0">
              <div class="flex gap-4 items-start">
                <div class="flex h-6 w-11 shrink-0 items-center justify-center text-amber-500" aria-hidden="true">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <p class="min-w-0 flex-1 pt-0.5 text-body leading-relaxed text-white/90">Bermondsey, London (SE1)</p>
              </div>

              <div class="flex gap-4 items-start">
                <div class="flex h-6 w-11 shrink-0 items-center justify-center text-amber-500" aria-hidden="true">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                </div>
                <a href="tel:+447773881815" class="min-w-0 flex-1 pt-0.5 text-body text-white/90 underline-offset-4 transition-colors hover:text-white hover:underline">
                  0777 388 1815
                </a>
              </div>

              <div class="flex gap-4 items-start">
                <div class="flex h-6 w-11 shrink-0 items-center justify-center text-amber-500" aria-hidden="true">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <a
                  href="mailto:Saramonsebeauty@gmail.com"
                  class="min-w-0 flex-1 break-words pt-0.5 text-body text-white/90 underline-offset-4 transition-colors hover:text-white hover:underline"
                >
                  Saramonsebeauty@gmail.com
                </a>
              </div>
            </div>

            <div class="flex gap-4 items-start min-w-0 border-t border-white/10 pt-8 lg:border-t-0 lg:border-l lg:border-white/10 lg:pl-10 lg:pt-0">
              <div class="flex h-6 w-11 shrink-0 items-center justify-center text-amber-500" aria-hidden="true">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <p class="mb-1.5 text-xs font-medium uppercase tracking-[0.2em] text-white/60">Business hours</p>
                <div class="space-y-1.5 text-body leading-relaxed text-white/90">
                  <p>Mon–Fri 10am–7pm</p>
                  <p>Sat 10am–6pm</p>
                  <p>Sun closed</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    ) : null
  }

  <div class={ftBg}>
    <div class="max-w-7xl mx-auto px-6 sm:px-8 py-16 sm:py-20">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div>
          <div class="mb-12">
            <img src="/assets/logo_128.png" alt="Sara Monse" width="128" height="128" />
          </div>

          <div class="mb-12 max-w-md">
            <h3 class:list={['text-xs font-semibold tracking-widest uppercase mb-6', ftText]}>
              Receive Updates Via Email
            </h3>
            {footerTheme === 'dark' ? (
              <form class="flex items-center gap-4 border-b border-white pb-3">
                <input
                  type="email"
                  placeholder="Enter your email"
                  class="flex-1 bg-transparent text-white placeholder:text-white/50 text-body font-light italic focus:outline-none"
                />
                <button type="submit" class="text-white hover:text-white/70 transition-colors shrink-0" aria-label="Subscribe">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                    />
                  </svg>
                </button>
              </form>
            ) : (
              <form class="flex items-center gap-4 border-b border-gray-900 pb-3">
                <input
                  type="email"
                  placeholder="Enter your email"
                  class="flex-1 bg-transparent text-gray-900 placeholder:text-gray-400 text-body font-light italic focus:outline-none"
                />
                <button type="submit" class="text-gray-900 hover:text-gray-600 transition-colors shrink-0" aria-label="Subscribe">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                    />
                  </svg>
                </button>
              </form>
            )}
          </div>

          <div class="flex gap-6">
            <a
              href="https://instagram.com"
              target="_blank"
              rel="noopener noreferrer"
              class:list={[ftSocial, 'transition-colors']}
              aria-label="Instagram"
            >
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
              </svg>
            </a>
            <a
              href="https://facebook.com"
              target="_blank"
              rel="noopener noreferrer"
              class:list={[ftSocial, 'transition-colors']}
              aria-label="Facebook"
            >
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
            </a>
            <a
              href="https://tiktok.com"
              target="_blank"
              rel="noopener noreferrer"
              class:list={[ftSocial, 'transition-colors']}
              aria-label="TikTok"
            >
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z" />
              </svg>
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-8 lg:gap-16">
          <div>
            <ul class="space-y-6">
              {
                navigation.left.map((item) => {
                  const groupId = `footer-nav-${item.label.replace(/\s+/g, '-').toLowerCase()}`;
                  const childList =
                    item.children?.length ? (
                      <ul
                        class:list={[
                          'mt-2.5 list-none space-y-2.5 border-l pl-5',
                          ftNavChildRule,
                        ]}
                      >
                        {item.children.map((child) => (
                          <li>
                            <a href={child.href} class:list={ftNavChild}>
                              {child.label}
                            </a>
                          </li>
                        ))}
                      </ul>
                    ) : null;

                  return item.children?.length && !item.parentLink ? (
                    <li>
                      <div role="group" aria-labelledby={groupId}>
                        <span id={groupId} class:list={[ftTextMuted, 'block text-sm font-normal']}>
                          {item.label}
                        </span>
                        {childList}
                      </div>
                    </li>
                  ) : (
                    <li>
                      {item.children?.length && item.parentLink ? (
                        <div role="group" aria-labelledby={groupId}>
                          <a
                            id={groupId}
                            href={item.href}
                            class:list={[ftTextMuted, ftTextHover, 'text-sm transition-colors']}
                          >
                            {item.label}
                          </a>
                          {childList}
                        </div>
                      ) : (
                        <a href={item.href} class:list={[ftTextMuted, ftTextHover, 'transition-colors text-sm']}>
                          {item.label}
                        </a>
                      )}
                    </li>
                  );
                })
              }
            </ul>
          </div>

          <div>
            <ul class="space-y-6">
              {
                navigation.right.map((item) => (
                  <li>
                    <a href={item.href} class:list={[ftTextMuted, ftTextHover, 'transition-colors text-sm']}>
                      {item.label}
                    </a>
                  </li>
                ))
              }
              <li>
                <a href="/privacy-policy" class:list={[ftTextMuted, ftTextHover, 'transition-colors text-sm']}>
                  Privacy Policy
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class:list={[ftBg, 'border-t', ftBottomBorder]}>
    <div class="max-w-7xl mx-auto px-6 sm:px-8 py-8">
      <div class:list={['grid sm:grid-cols-2 gap-6 text-sm font-sans', ftBottomText]}>
        <div class="flex flex-wrap gap-4 sm:gap-6 justify-start">
          <a href="/privacy-policy" class:list={[ftBottomHover, 'transition-colors']}>
            Terms & Conditions
          </a>
          <a href="/privacy-policy" class:list={[ftBottomHover, 'transition-colors']}>
            Security & Privacy
          </a>
        </div>
        <div class="text-center sm:text-right">
          <p>&copy; {currentYear} Sara Monse Ltd</p>
        </div>
      </div>
    </div>
  </div>
</footer>
