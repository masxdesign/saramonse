---
import navigation from '../data/navigation.js';
import contact from '../data/contact.json';
import { FACEBOOK_URL, INSTAGRAM_URL, TIKTOK_URL } from '../data/site-urls.js';

const { location, phone, email, hours, social } = contact;
const mailtoHref = `mailto:${email}`;
const telHref = `tel:${phone.telHref}`;

interface Props {
  footerTheme?: 'light' | 'dark';
  isHomepage?: boolean;
}

const { footerTheme = 'light', isHomepage = false } = Astro.props;

const currentYear = new Date().getFullYear();

const ftBg = footerTheme === 'dark' ? 'bg-black' : 'bg-white';
const ftText = footerTheme === 'dark' ? 'text-white' : 'text-gray-900';
/** Primary footer nav + labels: light sans (mockup-style), not body serif */
const ftTextMuted = footerTheme === 'dark' ? 'text-white/90 font-light' : 'text-gray-700 font-light';
const ftTextHover = footerTheme === 'dark' ? 'hover:text-white' : 'hover:text-gray-900';
const ftSocial =
  footerTheme === 'dark' ? 'text-white hover:text-white/70' : 'text-gray-900 hover:text-gray-600';
const ftBottomBorder = footerTheme === 'dark' ? 'border-white/20' : 'border-gray-200';
const ftBottomText = footerTheme === 'dark' ? 'text-white/70 font-light' : 'text-gray-600 font-light';
/** Nested footer links: lighter weight + softer tone vs primary row (Home / Services label). */
const ftNavChild =
  footerTheme === 'dark'
    ? 'text-white/65 font-light text-sm tracking-wide transition-colors hover:text-white'
    : 'text-gray-500 font-light text-sm tracking-wide transition-colors hover:text-gray-900';
const ftNavChildRule = footerTheme === 'dark' ? 'border-white/15' : 'border-gray-200/90';
---

<footer class="footer-font-sans antialiased">
  {
    isHomepage ? (
      <div id="lets-talk-section" class="relative overflow-hidden bg-black text-white">
        <video
          class="lazy-footer-bg-video pointer-events-none absolute inset-0 h-full w-full object-cover object-right will-change-transform md:object-center md:inset-y-0 md:left-auto md:right-0 md:h-full md:w-auto md:max-w-none md:shrink-0 md:origin-right md:scale-[2]"
          data-video-webm="/assets/rain-green-leaf.small.webm?t=2"
          data-video-mp4="/assets/rain-green-leaf.small.mp4?t=2"
          poster="/assets/rain-green-leaf-poster.webp?t=2"
          preload="none"
          muted
          loop
          playsinline
          aria-hidden="true"
        ></video>
        <div
          class="absolute inset-0 z-[1] bg-gradient-to-b from-black/42 via-black/22 to-black/38"
          aria-hidden="true"
        />

        <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-8 py-16 sm:py-20">
          <h2
            class="text-3xl sm:text-4xl lg:text-5xl font-light mb-10 sm:mb-12 tracking-wide text-left text-white"
            style="font-family: 'Cormorant Garamond', 'Georgia', serif;"
          >
            Let's Talk
          </h2>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start font-sans text-white/90">
            <div class="space-y-10 min-w-0">
              <div class="flex gap-4">
                <div
                  class="shrink-0 w-11 h-11 rounded-full border border-[#d4af37] flex items-center justify-center text-[#d4af37]"
                  aria-hidden="true"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <p class="text-body pt-2 leading-relaxed text-white/90">{location.short}</p>
              </div>

              <div class="flex gap-4">
                <div
                  class="shrink-0 w-11 h-11 rounded-full border border-[#d4af37] flex items-center justify-center text-[#d4af37]"
                  aria-hidden="true"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                </div>
                <p class="text-body pt-2">
                  <a href={telHref} class="text-white/90 hover:underline">{phone.display}</a>
                </p>
              </div>

              <div class="flex gap-4">
                <div
                  class="shrink-0 w-11 h-11 rounded-full border border-[#d4af37] flex items-center justify-center text-[#d4af37]"
                  aria-hidden="true"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <p class="text-body pt-2 break-all">
                  <a href={mailtoHref} class="text-white/90 hover:underline">{email}</a>
                </p>
              </div>
            </div>

            <div class="flex gap-4 items-start min-w-0 border-t border-white/10 pt-8 lg:border-t-0 lg:border-l lg:border-white/10 lg:pl-10 lg:pt-0">
              <div
                class="shrink-0 w-11 h-11 rounded-full border border-[#d4af37] flex items-center justify-center text-[#d4af37] mt-0.5"
                aria-hidden="true"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-xs font-sans tracking-wide text-white/90 mb-3">{hours.heading}</p>
                <div class="grid grid-cols-[auto_1fr] gap-x-8 gap-y-2 text-body text-white/90">
                  {hours.contactGrid.map((row) => (
                    <>
                      <span class="tabular-nums">{row.day}</span>
                      <span>{row.time}</span>
                    </>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    ) : null
  }

  <div
    id={footerTheme === 'dark' ? 'footer-dark-video' : undefined}
    class:list={[footerTheme === 'dark' ? 'relative overflow-hidden bg-black text-white' : undefined]}
  >
    {
      footerTheme === 'dark' ? (
        <>
          <video
            class="lazy-footer-bg-video pointer-events-none absolute inset-0 w-full object-cover object-left max-md:h-full md:object-center"
            data-video-webm="/assets/green-leafs.small.webm?t=1"
            data-video-mp4="/assets/green-leafs.small.mp4?t=1"
            poster="/assets/green-leafs-poster.webp"
            preload="none"
            muted
            loop
            playsinline
            aria-hidden="true"
          ></video>
          <div
            class="absolute inset-0 z-[1] bg-gradient-to-b from-black/60 via-black/40 to-black/55"
            aria-hidden="true"
          />
        </>
      ) : null
    }
    <div class:list={[footerTheme === 'dark' ? 'relative z-10' : ftBg]}>
      <div class="max-w-7xl mx-auto px-6 sm:px-8 py-16 sm:py-20">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div>
          <div class="mb-12">
            <img src="/assets/logo_256.png" alt="Sara Monse" width="128" height="128" />
          </div>

          <div class="mb-12 max-w-md">
            <h3
              class:list={[
                'text-base sm:text-lg font-light tracking-[0.18em] uppercase mb-6 leading-snug',
                ftText,
              ]}
            >
              Receive Updates Via Email
            </h3>
            {footerTheme === 'dark' ? (
              <form
                class="footer-subscribe-form flex flex-col gap-2"
                data-subscribe-theme="dark"
                novalidate
                aria-busy="false"
              >
                <div class="flex items-center gap-4 border-b border-white pb-3">
                  <input
                    type="email"
                    name="email"
                    required
                    autocomplete="email"
                    inputmode="email"
                    maxlength="254"
                    placeholder="Enter your email"
                    aria-describedby="footer-subscribe-status-dark"
                    class="footer-subscribe-email flex-1 bg-transparent text-white placeholder:text-white/45 text-body font-light italic focus:outline-none"
                  />
                  <button
                    type="submit"
                    class="footer-subscribe-submit text-white hover:text-white/70 transition-colors shrink-0 disabled:opacity-50"
                    aria-label="Subscribe to email updates"
                  >
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                      />
                    </svg>
                  </button>
                </div>
                <p
                  id="footer-subscribe-status-dark"
                  class="footer-subscribe-status text-xs font-sans min-h-[1.25rem] text-white/60"
                  role="status"
                  aria-live="polite"
                ></p>
              </form>
            ) : (
              <form
                class="footer-subscribe-form flex flex-col gap-2"
                data-subscribe-theme="light"
                novalidate
                aria-busy="false"
              >
                <div class="flex items-center gap-4 border-b border-gray-900 pb-3">
                  <input
                    type="email"
                    name="email"
                    required
                    autocomplete="email"
                    inputmode="email"
                    maxlength="254"
                    placeholder="Enter your email"
                    aria-describedby="footer-subscribe-status-light"
                    class="footer-subscribe-email flex-1 bg-transparent text-gray-900 placeholder:text-gray-500 text-body font-light italic focus:outline-none"
                  />
                  <button
                    type="submit"
                    class="footer-subscribe-submit text-gray-900 hover:text-gray-600 transition-colors shrink-0 disabled:opacity-50"
                    aria-label="Subscribe to email updates"
                  >
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                      />
                    </svg>
                  </button>
                </div>
                <p
                  id="footer-subscribe-status-light"
                  class="footer-subscribe-status text-xs font-sans min-h-[1.25rem] text-gray-500"
                  role="status"
                  aria-live="polite"
                ></p>
              </form>
            )}
          </div>

          <div class="flex gap-6">
            <a
              href={INSTAGRAM_URL}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[ftSocial, 'transition-colors']}
              aria-label={`Instagram @${social.instagramHandle}`}
            >
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
              </svg>
            </a>
            <a
              href={FACEBOOK_URL}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[ftSocial, 'transition-colors']}
              aria-label="Facebook — Sara Monse Beauty"
            >
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
            </a>
            <a
              href={TIKTOK_URL}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[ftSocial, 'transition-colors']}
              aria-label="TikTok @saramonsebeauty"
            >
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.63-5.71-.02-.5-.01-1-.01-1.49-.18-1.86.36-3.78 1.53-5.25 1.17-1.48 2.99-2.5 4.95-2.71.5-.02 1-.01 1.49-.01v4c-.66-.02-1.3.18-1.84.5-.88.52-1.41 1.58-1.29 2.6.1.83.57 1.6 1.25 2.07.73.51 1.7.67 2.59.46.68-.16 1.27-.58 1.66-1.17.32-.5.48-1.1.47-1.69v-8.4z"
                />
              </svg>
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-8 lg:gap-16">
          <div>
            <ul class="space-y-8">
              {
                navigation.left.map((item) => {
                  const groupId = `footer-nav-${item.label.replace(/\s+/g, '-').toLowerCase()}`;
                  const childList =
                    item.children?.length ? (
                      <ul
                        class:list={[
                          'mt-5 sm:mt-6 list-none space-y-2.5 border-l pl-5',
                          ftNavChildRule,
                        ]}
                      >
                        {item.children.map((child) => (
                          <li>
                            <a href={child.href} class:list={ftNavChild}>
                              {child.label}
                            </a>
                          </li>
                        ))}
                      </ul>
                    ) : null;

                  return item.children?.length && !item.parentLink ? (
                    <li>
                      <div role="group" aria-labelledby={groupId}>
                        <span id={groupId} class:list={[ftTextMuted, 'block text-sm']}>
                          {item.label}
                        </span>
                        {childList}
                      </div>
                    </li>
                  ) : (
                    <li>
                      {item.children?.length && item.parentLink ? (
                        <div role="group" aria-labelledby={groupId}>
                          <a
                            id={groupId}
                            href={item.href}
                            class:list={[ftTextMuted, ftTextHover, 'text-sm transition-colors']}
                          >
                            {item.label}
                          </a>
                          {childList}
                        </div>
                      ) : (
                        <a href={item.href} class:list={[ftTextMuted, ftTextHover, 'transition-colors text-sm']}>
                          {item.label}
                        </a>
                      )}
                    </li>
                  );
                })
              }
            </ul>
          </div>

          <div>
            <ul class="space-y-8">
              {
                navigation.right.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      target={item.external ? '_blank' : undefined}
                      rel={item.external ? 'noopener noreferrer' : undefined}
                      class:list={[ftTextMuted, ftTextHover, 'transition-colors text-sm']}
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
              <li>
                <a href="/privacy-policy" class:list={[ftTextMuted, ftTextHover, 'transition-colors text-sm']}>
                  Privacy Policy
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    </div>

    <div
      class:list={[
        footerTheme === 'dark' ? 'relative z-10 border-t border-white/20' : [ftBg, 'border-t', ftBottomBorder],
      ]}
    >
      <div class="max-w-7xl mx-auto px-6 sm:px-8 py-8">
        <p class:list={['text-center text-sm font-sans', ftBottomText]}>&copy; {currentYear} Sara Monse Ltd</p>
      </div>
    </div>

  </div>

  <script is:inline>
    (function () {
      var videos = document.querySelectorAll('video.lazy-footer-bg-video');
      if (!videos.length) return;

      /** Start loading ~200px before the footer enters the viewport */
      var ioOpts = { rootMargin: '0px 0px 200px 0px', threshold: 0 };

      function tryPlay(el) {
        var p = el.play();
        if (p && typeof p.then === 'function') p.catch(function () {});
      }

      function hydrate(el) {
        if (el.getAttribute('data-lazy-hydrated') === '1') return;
        el.setAttribute('data-lazy-hydrated', '1');

        var webm = el.getAttribute('data-video-webm');
        var mp4 = el.getAttribute('data-video-mp4');
        if (webm) {
          var s = document.createElement('source');
          s.src = webm;
          s.type = 'video/webm';
          el.appendChild(s);
        }
        if (mp4) {
          var s2 = document.createElement('source');
          s2.src = mp4;
          s2.type = 'video/mp4';
          el.appendChild(s2);
        }

        el.defaultMuted = true;
        el.muted = true;
        el.setAttribute('muted', '');
        el.setAttribute('playsinline', '');
        el.playsInline = true;
        try {
          el.setAttribute('webkit-playsinline', '');
        } catch (e) {}

        el.addEventListener(
          'canplay',
          function onCan() {
            el.removeEventListener('canplay', onCan);
            tryPlay(el);
          },
          { once: true }
        );

        el.load();
        if (el.readyState >= 2) tryPlay(el);
      }

      videos.forEach(function (el) {
        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                hydrate(el);
                io.unobserve(el);
              }
            });
          }, ioOpts);
          io.observe(el);
        } else {
          hydrate(el);
        }
      });

      document.addEventListener('visibilitychange', function () {
        if (document.hidden) return;
        videos.forEach(function (el) {
          if (el.getAttribute('data-lazy-hydrated') === '1' && el.paused) tryPlay(el);
        });
      });
      window.addEventListener('pageshow', function () {
        videos.forEach(function (el) {
          if (el.getAttribute('data-lazy-hydrated') === '1' && el.paused) tryPlay(el);
        });
      });
    })();
  </script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var forms = document.querySelectorAll('form.footer-subscribe-form');
      if (!forms.length) return;

      var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      function setStatus(form, statusEl, message, kind) {
        var theme = form.getAttribute('data-subscribe-theme') || 'light';
        statusEl.textContent = message || '';
        statusEl.classList.remove(
          'text-white/60',
          'text-white/90',
          'text-red-300',
          'text-emerald-300',
          'text-gray-500',
          'text-gray-700',
          'text-red-800',
          'text-green-800'
        );
        if (!message) {
          statusEl.classList.add(theme === 'dark' ? 'text-white/60' : 'text-gray-500');
          return;
        }
        if (kind === 'ok') {
          statusEl.classList.add(theme === 'dark' ? 'text-emerald-300' : 'text-green-800');
        } else if (kind === 'err') {
          statusEl.classList.add(theme === 'dark' ? 'text-red-300' : 'text-red-800');
        } else {
          statusEl.classList.add(theme === 'dark' ? 'text-white/90' : 'text-gray-700');
        }
      }

      forms.forEach(function (form) {
        var input = form.querySelector('input.footer-subscribe-email');
        var statusEl = form.querySelector('.footer-subscribe-status');
        var btn = form.querySelector('button.footer-subscribe-submit');
        if (!input || !statusEl || !(input instanceof HTMLInputElement) || !(btn instanceof HTMLButtonElement)) return;

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var email = input.value.trim();
          if (!email) {
            setStatus(form, statusEl, 'Please enter your email address.', 'err');
            input.focus();
            return;
          }
          if (!EMAIL_RE.test(email)) {
            setStatus(form, statusEl, 'Please enter a valid email address.', 'err');
            input.focus();
            return;
          }

          form.setAttribute('aria-busy', 'true');
          btn.disabled = true;
          setStatus(form, statusEl, '', 'muted');

          fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email }),
          })
            .then(function (res) {
              return res.text().then(function (text) {
                var data = {};
                if (text) {
                  try {
                    data = JSON.parse(text);
                  } catch (err) {
                    data = {};
                  }
                }
                return { res: res, data: data };
              });
            })
            .then(function (ref) {
              var res = ref.res;
              var data = ref.data;
              if (res.ok && data && data.ok === true) {
                if (data.alreadySubscribed) {
                  setStatus(form, statusEl, "You're already on the list.", 'ok');
                } else {
                  setStatus(form, statusEl, "Thanks — you're subscribed.", 'ok');
                  input.value = '';
                }
              } else {
                var msg =
                  data && typeof data.error === 'string'
                    ? data.error
                    : res.status === 404
                      ? 'Signup unavailable. Try again later.'
                      : 'Something went wrong. Please try again.';
                setStatus(form, statusEl, msg, 'err');
              }
            })
            .catch(function () {
              setStatus(form, statusEl, 'Network error. Check your connection and try again.', 'err');
            })
            .finally(function () {
              form.setAttribute('aria-busy', 'false');
              btn.disabled = false;
            });
        });
      });
    });
  </script>
</footer>
