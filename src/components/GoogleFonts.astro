---
/**
 * Async font CSS: preload then apply as stylesheet on load (non–render-blocking).
 */
interface Props {
  variant?: 'hero' | 'full';
}

const { variant = 'full' } = Astro.props;
const href =
  variant === 'hero'
    ? 'https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600&family=Cormorant+Garamond:wght@300;400;500&display=swap'
    : 'https://fonts.googleapis.com/css2?family=Alex+Brush&family=Jost:wght@300;400;500;600&family=Cormorant+Garamond:wght@300;400;500&display=swap';
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preload" as="style" href={href} onload="this.onload=null;this.rel='stylesheet'" />
<noscript>
  <link rel="stylesheet" href={href} />
</noscript>
