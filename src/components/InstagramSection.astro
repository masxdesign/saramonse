---
import contact from '../data/contact.json';
import { INSTAGRAM_URL } from '../data/site-urls.js';

const igHandle = contact.social.instagramHandle;

/** Instagram logo path (single source for hover overlay tiles) */
const instagramIconPath =
  'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z';

const placeholderImages = [
  '/assets/instagram-1.png',
  '/assets/instagram-2.png',
  '/assets/instagram-3.png',
  '/assets/instagram-4.png',
  '/assets/instagram-5.png',
] as const;

interface Props {
  instagramProfileUrl?: string;
}

const { instagramProfileUrl = INSTAGRAM_URL } = Astro.props;
---

<section class="py-16 sm:py-20 lg:py-24 px-6 sm:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    <h2
      class="text-2xl sm:text-3xl lg:text-4xl text-center text-gray-900 font-light mb-12 sm:mb-16 tracking-wide"
      style="font-family: 'Cormorant Garamond', 'Georgia', serif;"
    >
      Follow us on Instagram{' '}
      <a
        href={instagramProfileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="no-underline"
        >@{igHandle}</a
      >
    </h2>

    <div
      class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-12"
    >
      {
        placeholderImages.map((src, index) => (
          <a
            href={instagramProfileUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="instagram-post aspect-square bg-beauty-light overflow-hidden relative group block cursor-pointer focus:outline-hidden focus-visible:ring-2 focus-visible:ring-gray-900 focus-visible:ring-offset-2"
            aria-label={`View @${igHandle} on Instagram (opens in a new tab) — image ${index + 1}`}
          >
            <img
              src={src}
              alt=""
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all duration-300 flex items-center justify-center pointer-events-none">
              <svg
                class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d={instagramIconPath} />
              </svg>
            </div>
          </a>
        ))
      }
    </div>

    <div class="flex justify-center">
      <a
        href={instagramProfileUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`View more on Instagram @${igHandle} (opens in a new tab)`}
        class="inline-block px-12 py-4 border-2 border-gray-900 text-gray-900 font-sans font-medium tracking-wider uppercase text-sm hover:bg-gray-900 hover:text-white transition-all text-center"
      >
        Load More
      </a>
    </div>
  </div>
</section>
