---
import type { ServiceMenu } from '../data/menus/types';

interface Props {
  menu: ServiceMenu;
  /** Applied to the row that wraps the default slot (e.g. Book Treatment). */
  primaryRowClass?: string;
  /** When true, centers the “Download price list” label and PDF links (e.g. match a centered Book button). */
  centerDownloads?: boolean;
}

const { menu, primaryRowClass = '', centerDownloads = false } = Astro.props;

const fullBrochureHref = '/assets/all-services-menu.pdf';
const sectionPdfHref = `/assets/${menu.pdfFileName}`;
---

<div class="max-w-4xl mx-auto flex flex-col gap-8">
  <div class:list={['flex flex-wrap gap-6', primaryRowClass]}>
    <slot />
  </div>
  <div
    class:list={[
      'border-t border-gray-200 pt-6 sm:pt-8',
      centerDownloads ? 'text-center' : '',
    ]}
  >
    <p
      class="font-sans text-xs tracking-[0.25em] uppercase text-gray-500 mb-4"
    >
      Download price list
    </p>
    <div
      class:list={['flex flex-wrap gap-4', centerDownloads ? 'justify-center' : '']}
    >
      <a
        href={fullBrochureHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block border border-gray-900 text-gray-900 font-sans text-sm tracking-[0.2em] uppercase px-8 py-4 hover:bg-gray-900 hover:text-white transition-colors"
      >
        Full salon menu (PDF)
      </a>
      <a
        href={sectionPdfHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block border border-gray-900 text-gray-900 font-sans text-sm tracking-[0.2em] uppercase px-8 py-4 hover:bg-gray-900 hover:text-white transition-colors"
      >
        {menu.displayName} only (PDF)
      </a>
    </div>
  </div>
</div>
