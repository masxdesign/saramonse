---
import type { ExtrasCell } from '../../data/menus/types';
import { extrasAmountDisplay } from './menu-format';

interface Props {
  cell: ExtrasCell;
}

const { cell } = Astro.props;
---

{
  cell.mode === 'dash' ? null : (
    <span class="inline-flex items-baseline gap-1.5 font-sans text-gray-900 tabular-nums">
      {
        cell.mode === 'from' ? (
          <>
            <span class="text-sm font-normal">From</span>
            <span class="text-lg sm:text-xl font-bold tabular-nums">{extrasAmountDisplay(cell)}</span>
          </>
        ) : cell.mode === 'literal' ? (
          <span class="text-lg sm:text-xl font-bold tabular-nums">{cell.text}</span>
        ) : (
          <span class="text-lg sm:text-xl font-bold tabular-nums">{extrasAmountDisplay(cell)}</span>
        )
      }
    </span>
  )
}
