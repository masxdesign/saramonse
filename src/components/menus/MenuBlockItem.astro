---
import type { MenuBlock } from '../../data/menus/types';
import MenuComingSoon from './MenuComingSoon.astro';
import MenuExtrasGrid from './MenuExtrasGrid.astro';
import MenuFatDissolve from './MenuFatDissolve.astro';
import MenuProse from './MenuProse.astro';
import MenuRemovalGroup from './MenuRemovalGroup.astro';
import MenuRichRow from './MenuRichRow.astro';
import MenuSimpleRow from './MenuSimpleRow.astro';
import MenuSlotRow from './MenuSlotRow.astro';

interface Props {
  block: MenuBlock;
}

const { block } = Astro.props;
---

{
  block.type === 'section' ? (
    <h2
      class="text-2xl sm:text-3xl lg:text-4xl text-gray-900 font-light tracking-[0.3em] uppercase mb-6"
      style="font-family: 'Cormorant Garamond', 'Georgia', serif;"
    >
      {block.title}
    </h2>
  ) : block.type === 'simpleRow' ? (
    <MenuSimpleRow block={block} />
  ) : block.type === 'richRow' ? (
    <MenuRichRow block={block} />
  ) : block.type === 'slotRow' ? (
    <MenuSlotRow block={block} />
  ) : block.type === 'fatDissolve' ? (
    <MenuFatDissolve block={block} />
  ) : block.type === 'comingSoon' ? (
    <MenuComingSoon block={block} />
  ) : block.type === 'extrasGrid' ? (
    <MenuExtrasGrid block={block} />
  ) : block.type === 'removalGroup' ? (
    <MenuRemovalGroup block={block} />
  ) : block.type === 'prose' ? (
    <MenuProse block={block} />
  ) : null
}
