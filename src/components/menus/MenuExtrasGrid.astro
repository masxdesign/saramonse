---
import type { ExtrasCell, MenuBlock } from '../../data/menus/types';
import ExtrasPriceCell from './ExtrasPriceCell.astro';

interface Props {
  block: Extract<MenuBlock, { type: 'extrasGrid' }>;
}

const { block } = Astro.props;
const single = Boolean(block.singleColumn);
const priceHeader = block.columnLabels[0].trim();

/** Omit Hands/Feet column entirely when data is unavailable (dash). */
function extrasColumnVisible(cell: ExtrasCell): boolean {
  return cell.mode !== 'dash';
}
---

<div class="max-w-3xl mb-10">
  {
    block.title ? (
      <h3
        class="text-xl sm:text-2xl lg:text-3xl text-gray-900 font-light tracking-[0.3em] uppercase mt-8 mb-4"
        style="font-family: 'Cormorant Garamond', 'Georgia', serif;"
      >
        {block.title}
      </h3>
    ) : null
  }

  <!-- Mobile: row title full width; price label(s) above amounts -->
  <div class="md:hidden">
    <div class="space-y-10">
      {
        block.rows.map((row) => {
          const showHands = extrasColumnVisible(row.hands);
          const showFeet = !single && extrasColumnVisible(row.feet);
          const priceCols = Number(showHands) + Number(showFeet);
          return (
            <div class="space-y-4 border-b border-gray-100 pb-10 last:border-b-0 last:pb-0">
              <p class="text-lg font-semibold text-gray-900 font-sans leading-snug">{row.name}</p>
              {priceCols > 0 && (
                <div
                  class:list={[
                    'grid gap-x-6 gap-y-2',
                    priceCols === 2 ? 'grid-cols-2' : 'grid-cols-1',
                  ]}
                >
                  {showHands && (
                    <div class="flex flex-wrap items-baseline justify-start gap-x-2 gap-y-0.5">
                      {priceHeader ? (
                        <span class="text-[11px] font-normal text-gray-500 uppercase tracking-wide shrink-0">
                          {block.columnLabels[0]}
                        </span>
                      ) : null}
                      <ExtrasPriceCell cell={row.hands} />
                    </div>
                  )}
                  {showFeet && (
                    <div class="flex flex-wrap items-baseline justify-start gap-x-2 gap-y-0.5">
                      <span class="text-[11px] font-normal text-gray-500 uppercase tracking-wide shrink-0">
                        {block.columnLabels[1]}
                      </span>
                      <ExtrasPriceCell cell={row.feet} />
                    </div>
                  )}
                </div>
              )}
            </div>
          );
        })
      }
    </div>
  </div>

  <!-- md+: compact table (two or three columns) -->
  <div
    class:list={[
      'hidden md:grid gap-x-6 gap-y-4 items-baseline justify-items-start',
      single ? 'md:grid-cols-[1.8fr_1fr]' : 'md:grid-cols-[1.6fr_1fr_1fr]',
    ]}
  >
    <div />
    {
      single && !priceHeader ? (
        <div />
      ) : (
        <p class="text-body-intro text-gray-900 font-light tracking-[0.25em] uppercase text-left self-start">
          {block.columnLabels[0]}
        </p>
      )
    }
    {!single ? (
      <p class="text-body-intro text-gray-900 font-light tracking-[0.25em] uppercase text-left self-start">
        {block.columnLabels[1]}
      </p>
    ) : null}
    {
      block.rows.map((row) => (
        <>
          <p class="text-lg sm:text-xl font-semibold text-gray-900 font-sans min-w-0 text-left">{row.name}</p>
          <div class="flex min-w-0 justify-start self-start font-sans text-gray-900 tabular-nums">
            {extrasColumnVisible(row.hands) ? <ExtrasPriceCell cell={row.hands} /> : null}
          </div>
          {!single ? (
            <div class="flex min-w-0 justify-start self-start font-sans text-gray-900 tabular-nums">
              {extrasColumnVisible(row.feet) ? <ExtrasPriceCell cell={row.feet} /> : null}
            </div>
          ) : null}
        </>
      ))
    }
  </div>

  {
    block.footerNote ? (
      <p class="text-body text-gray-700 font-sans leading-relaxed mt-6 max-w-2xl">{block.footerNote}</p>
    ) : null
  }
</div>
