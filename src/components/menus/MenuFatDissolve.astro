---
import type { MenuBlock } from '../../data/menus/types';
import { formatPounds } from './menu-format';

interface Props {
  block: Extract<MenuBlock, { type: 'fatDissolve' }>;
}

const { block } = Astro.props;
---

<div>
  <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 font-sans tracking-tight mb-8 sm:mb-10">
    {block.sectionTitle}
  </h3>
  <p class="text-body text-gray-900 font-sans font-normal leading-relaxed mb-12 sm:mb-14 lg:mb-16 max-w-3xl">
    {block.intro}
  </p>
  <p class="text-body text-gray-900 font-sans font-normal underline underline-offset-[5px] decoration-1 mb-8 sm:mb-10">
    {block.listHeading}
  </p>
  <div class="space-y-6 sm:space-y-7">
    {
      block.rows.map((row) => (
        <div class="flex flex-col gap-3 md:flex-row md:justify-between md:items-baseline md:gap-x-6">
          <p class="font-sans leading-relaxed min-w-0 md:flex-1 md:pr-2">
            <span class="font-bold text-body text-gray-900">{row.bold}</span>
            <span class="text-body text-gray-900 font-normal">
              {' '}- {row.detail}
            </span>
          </p>
          <div class="flex w-full shrink-0 justify-end md:w-44">
            <span class="inline-flex items-baseline gap-1.5 font-sans text-gray-900">
              <span class="text-sm font-normal">From</span>
              <span class="text-lg sm:text-xl font-bold tabular-nums">{formatPounds(row.fromAmount)}</span>
            </span>
          </div>
        </div>
      ))
    }
  </div>
  <p
    class="text-sm sm:text-body text-gray-600 font-sans font-normal leading-relaxed mt-14 sm:mt-16 lg:mt-20 max-w-3xl"
  >
    {block.footerNote}
  </p>
</div>
