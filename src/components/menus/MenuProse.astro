---
import type { MenuBlock } from '../../data/menus/types';

interface Props {
  block: Extract<MenuBlock, { type: 'prose' }>;
}

const { block } = Astro.props;
---

<p class="text-2xl text-gray-900 font-light italic text-center leading-relaxed max-w-4xl mx-auto mb-16 sm:mb-20">
  &ldquo;{block.text}&rdquo;
</p>
