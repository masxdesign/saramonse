---
import BaseLayout from '../layouts/BaseLayout.astro';
import contact from '../data/contact.json';

const { businessName, location, phone, email, hours, map } = contact;
const mailtoHref = `mailto:${email}`;
const telHref = `tel:${phone.telHref}`;
---

<BaseLayout
  title="Contact & opening hours | Saramonse Beauty"
  description="Contact Saramonse Beauty in Bermondsey, SE1: phone, email, map and opening hours. Book treatments or send enquiries — we’re happy to help."
  scrollCompactNav={true}
>
  <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" />

  <!-- Hero title: larger on mobile, ~45% from lg (matches design vs. w-11 / 44px icons) -->
  <section class="py-12 sm:py-16 lg:py-20 px-6 sm:px-8">
    <div class="max-w-5xl mx-auto flex justify-center">
      <h1 class="w-[88%] sm:w-[72%] md:w-[58%] lg:w-[45%] max-w-full shrink-0">
        <img
          src="/assets/get-in-touch-title.svg"
          alt="Get In Touch"
          class="block w-full h-auto mx-auto"
          width="530"
          height="168"
          loading="eager"
          decoding="async"
        />
      </h1>
    </div>
  </section>

  <!-- Form + details -->
  <section class="px-6 sm:px-8 pb-12 sm:pb-16">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 lg:items-start">
      <!-- Contact form -->
      <div>
        <form id="contact-form" class="space-y-4 max-w-md" novalidate aria-busy="false">
          <div class="space-y-0.5">
            <label for="contact-name" class="block text-xs font-sans font-normal tracking-wide text-gray-900 mb-1">Name</label>
            <input
              id="contact-name"
              name="name"
              type="text"
              autocomplete="name"
              required
              maxlength="200"
              aria-describedby="contact-name-error"
              aria-invalid="false"
              class="contact-field w-full bg-transparent border-0 border-b border-gray-900 pb-1.5 text-body text-gray-900 font-sans focus:outline-none focus:border-gray-600 aria-invalid:border-red-800 aria-invalid:focus:border-red-800"
            />
            <p id="contact-name-error" class="font-sans text-xs text-red-800 min-h-[1.125rem]" role="alert"></p>
          </div>
          <div class="space-y-0.5">
            <label for="contact-email" class="block text-xs font-sans font-normal tracking-wide text-gray-900 mb-1">Email</label>
            <input
              id="contact-email"
              name="email"
              type="email"
              inputmode="email"
              autocomplete="email"
              required
              maxlength="254"
              aria-describedby="contact-email-error"
              aria-invalid="false"
              class="contact-field w-full bg-transparent border-0 border-b border-gray-900 pb-1.5 text-body text-gray-900 font-sans focus:outline-none focus:border-gray-600 aria-invalid:border-red-800 aria-invalid:focus:border-red-800"
            />
            <p id="contact-email-error" class="font-sans text-xs text-red-800 min-h-[1.125rem]" role="alert"></p>
          </div>
          <div class="space-y-0.5">
            <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
              <label for="contact-message" class="block text-xs font-sans font-normal tracking-wide text-gray-900">Message</label>
              <span id="contact-message-hint" class="font-sans text-xs tabular-nums text-gray-500">0 / 8000</span>
            </div>
            <textarea
              id="contact-message"
              name="message"
              rows="6"
              required
              maxlength="8000"
              aria-describedby="contact-message-hint contact-message-error"
              aria-invalid="false"
              class="contact-field w-full border border-gray-900 px-3 py-1.5 text-body text-gray-900 font-sans focus:outline-none focus:ring-1 focus:ring-gray-900 focus:border-gray-900 resize-y min-h-[9rem] aria-invalid:border-red-800 aria-invalid:focus:ring-red-800"
            ></textarea>
            <p id="contact-message-error" class="font-sans text-xs text-red-800 min-h-[1.125rem]" role="alert"></p>
          </div>
          <p
            id="contact-form-status"
            class="font-sans text-body text-sm min-h-[1.25rem] text-gray-700 empty:hidden"
            role="status"
            aria-live="polite"
          ></p>
          <button
            id="contact-submit"
            type="submit"
            class="inline-flex items-center justify-center gap-2 min-w-[10.5rem] bg-gray-900 text-white font-sans text-sm tracking-[0.25em] uppercase px-10 py-4 hover:bg-gray-800 transition-colors disabled:opacity-60 disabled:pointer-events-none"
          >
            <span id="contact-submit-label">Submit</span>
            <span id="contact-submit-spinner" class="hidden size-4 shrink-0 border-2 border-white/30 border-t-white rounded-full animate-spin" aria-hidden="true"></span>
          </button>
        </form>
      </div>

      <!-- Business info -->
      <div class="space-y-10 font-sans text-gray-900">
        <div class="flex gap-4">
          <div class="shrink-0 w-11 h-11 rounded-full border border-gray-900 flex items-center justify-center" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <p class="text-body pt-2 leading-relaxed">
            {location.short}
          </p>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-11 h-11 rounded-full border border-gray-900 flex items-center justify-center" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
          </div>
          <p class="text-body pt-2">
            <a href={telHref} class="hover:underline">{phone.display}</a>
          </p>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-11 h-11 rounded-full border border-gray-900 flex items-center justify-center" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <p class="text-body pt-2 break-all">
            <a href={mailtoHref} class="hover:underline">{email}</a>
          </p>
        </div>

        <div class="flex gap-4 items-start">
          <div class="shrink-0 w-11 h-11 rounded-full border border-gray-900 flex items-center justify-center mt-0.5" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-xs font-sans tracking-wide text-gray-900 mb-3">{hours.heading}</p>
            <div class="grid grid-cols-[auto_1fr] gap-x-8 gap-y-2 text-body text-gray-900">
              {hours.contactGrid.map((row) => (
                <>
                  <span class="tabular-nums">{row.day}</span>
                  <span>{row.time}</span>
                </>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="w-full mt-4 sm:mt-8">
    <div id="map" class="w-full h-[min(50vh,28rem)] min-h-[280px] bg-gray-100" role="region" aria-label="Map showing salon location"></div>
  </section>

  <script is:inline src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  <script
    define:vars={{
      mapLat: map.lat,
      mapLng: map.lng,
      mapJitterRadiusM: map.jitterRadiusM,
      contactBusinessName: businessName,
      contactLocationShort: location.short,
    }}
  >
    document.addEventListener('DOMContentLoaded', function () {
      var form = document.getElementById('contact-form');
      var statusEl = document.getElementById('contact-form-status');
      var submitBtn = document.getElementById('contact-submit');
      var submitLabel = document.getElementById('contact-submit-label');
      var submitSpinner = document.getElementById('contact-submit-spinner');
      var messageHint = document.getElementById('contact-message-hint');

      var MAX_NAME = 200;
      var MAX_EMAIL = 254;
      var MAX_MESSAGE = 8000;
      var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      function fieldRefs() {
        var name = document.getElementById('contact-name');
        var emailEl = document.getElementById('contact-email');
        var messageEl = document.getElementById('contact-message');
        if (!name || !emailEl || !messageEl) return null;
        if (!(name instanceof HTMLInputElement) || !(emailEl instanceof HTMLInputElement) || !(messageEl instanceof HTMLTextAreaElement)) return null;
        return {
          name: name,
          email: emailEl,
          message: messageEl,
          nameErr: document.getElementById('contact-name-error'),
          emailErr: document.getElementById('contact-email-error'),
          messageErr: document.getElementById('contact-message-error'),
        };
      }

      function clearFieldError(input, errEl) {
        input.setAttribute('aria-invalid', 'false');
        if (errEl) errEl.textContent = '';
      }

      function setFieldError(input, errEl, msg) {
        input.setAttribute('aria-invalid', 'true');
        if (errEl) errEl.textContent = msg;
      }

      function clearAllFieldErrors(f) {
        if (!f) return;
        clearFieldError(f.name, f.nameErr);
        clearFieldError(f.email, f.emailErr);
        clearFieldError(f.message, f.messageErr);
      }

      function updateMessageCount(f) {
        if (!messageHint || !f) return;
        var n = f.message.value.length;
        messageHint.textContent = n + ' / ' + MAX_MESSAGE;
        if (n >= MAX_MESSAGE) {
          messageHint.classList.add('text-red-800');
          messageHint.classList.remove('text-gray-500');
        } else {
          messageHint.classList.remove('text-red-800');
          messageHint.classList.add('text-gray-500');
        }
      }

      function validateClient(f) {
        clearAllFieldErrors(f);
        var ok = true;
        var firstBad = null;

        var nameV = f.name.value.trim();
        if (!nameV) {
          setFieldError(f.name, f.nameErr, 'Please enter your name.');
          ok = false;
          firstBad = firstBad || f.name;
        } else if (nameV.length > MAX_NAME) {
          setFieldError(f.name, f.nameErr, 'Name is too long (max ' + MAX_NAME + ' characters).');
          ok = false;
          firstBad = firstBad || f.name;
        }

        var emailV = f.email.value.trim();
        if (!emailV) {
          setFieldError(f.email, f.emailErr, 'Please enter your email address.');
          ok = false;
          firstBad = firstBad || f.email;
        } else if (emailV.length > MAX_EMAIL) {
          setFieldError(f.email, f.emailErr, 'Email is too long.');
          ok = false;
          firstBad = firstBad || f.email;
        } else if (!EMAIL_RE.test(emailV)) {
          setFieldError(f.email, f.emailErr, 'Please enter a valid email address.');
          ok = false;
          firstBad = firstBad || f.email;
        }

        var msgV = f.message.value.trim();
        if (!msgV) {
          setFieldError(f.message, f.messageErr, 'Please enter a message.');
          ok = false;
          firstBad = firstBad || f.message;
        } else if (f.message.value.length > MAX_MESSAGE) {
          setFieldError(f.message, f.messageErr, 'Message is too long (max ' + MAX_MESSAGE + ' characters).');
          ok = false;
          firstBad = firstBad || f.message;
        }

        if (firstBad) firstBad.focus();
        return ok;
      }

      function setSending(sending) {
        if (!form || !submitBtn || !submitLabel || !submitSpinner) return;
        form.setAttribute('aria-busy', sending ? 'true' : 'false');
        submitBtn.disabled = sending;
        submitLabel.textContent = sending ? 'Sending…' : 'Submit';
        submitSpinner.classList.toggle('hidden', !sending);
      }

      if (form && statusEl && submitBtn && submitBtn instanceof HTMLButtonElement) {
        var f0 = fieldRefs();
        if (f0) {
          f0.message.addEventListener('input', function () {
            updateMessageCount(f0);
            if (f0.message.getAttribute('aria-invalid') === 'true') clearFieldError(f0.message, f0.messageErr);
          });
          ['name', 'email'].forEach(function (key) {
            f0[key].addEventListener('input', function () {
              if (f0[key].getAttribute('aria-invalid') === 'true') clearFieldError(f0[key], f0[key + 'Err']);
            });
            f0[key].addEventListener('blur', function () {
              var refs = fieldRefs();
              if (!refs) return;
              if (key === 'name') {
                var v = refs.name.value.trim();
                if (v && v.length > MAX_NAME) setFieldError(refs.name, refs.nameErr, 'Name is too long (max ' + MAX_NAME + ' characters).');
              }
              if (key === 'email') {
                var ev = refs.email.value.trim();
                if (ev && !EMAIL_RE.test(ev)) setFieldError(refs.email, refs.emailErr, 'Please enter a valid email address.');
              }
            });
          });
          updateMessageCount(f0);
        }

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var f = fieldRefs();
          if (!f) return;

          statusEl.textContent = '';
          statusEl.classList.remove('text-red-800', 'text-green-900');
          statusEl.classList.add('text-gray-700');

          if (!validateClient(f)) {
            statusEl.textContent = 'Please correct the fields above.';
            statusEl.classList.remove('text-gray-700');
            statusEl.classList.add('text-red-800');
            return;
          }

          setSending(true);

          fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: f.name.value.trim(),
              email: f.email.value.trim(),
              message: f.message.value.trim(),
            }),
          })
            .then(function (res) {
              return res.text().then(function (text) {
                var data = {};
                if (text) {
                  try {
                    data = JSON.parse(text);
                  } catch (parseErr) {
                    data = {};
                  }
                }
                return { res: res, data: data };
              });
            })
            .then(function (_ref) {
              var res = _ref.res;
              var data = _ref.data;
              if (res.ok && data && data.ok === true) {
                clearAllFieldErrors(f);
                statusEl.textContent = 'Thank you — your message has been sent. We will get back to you soon.';
                statusEl.classList.remove('text-red-800');
                statusEl.classList.add('text-green-900');
                form.reset();
                updateMessageCount(fieldRefs() || f);
              } else {
                var msg =
                  data && typeof data.error === 'string'
                    ? data.error
                    : res.status === 404
                      ? 'Form endpoint not found. If you are testing locally, run wrangler dev (with Astro proxy) or npm run worker:dev.'
                      : 'Something went wrong. Please try again or email us directly.';
                statusEl.textContent = msg;
                statusEl.classList.remove('text-gray-700', 'text-green-900');
                statusEl.classList.add('text-red-800');
                if (res.status === 400 && msg.indexOf('email') !== -1) {
                  setFieldError(f.email, f.emailErr, msg);
                  f.email.focus();
                }
              }
            })
            .catch(function () {
              statusEl.textContent = 'Network error. Check your connection and try again.';
              statusEl.classList.remove('text-gray-700', 'text-green-900');
              statusEl.classList.add('text-red-800');
            })
            .finally(function () {
              setSending(false);
            });
        });
      }

      if (typeof maplibregl === 'undefined') return;
      var el = document.getElementById('map');
      if (!el) return;

      var lat = mapLat;
      var lng = mapLng;

      /** Uniform random point within `radiusM` metres of (lat, lng); pin does not show exact address. */
      function jitterLatLng(lat0, lng0, radiusM) {
        var theta = Math.random() * 2 * Math.PI;
        var r = radiusM * Math.sqrt(Math.random());
        var metersEast = r * Math.cos(theta);
        var metersNorth = r * Math.sin(theta);
        var latRad = (lat0 * Math.PI) / 180;
        var metersPerDegLat = 111320;
        var metersPerDegLng = 111320 * Math.cos(latRad);
        return {
          lat: lat0 + metersNorth / metersPerDegLat,
          lng: lng0 + metersEast / metersPerDegLng,
        };
      }

      var pin = jitterLatLng(lat, lng, mapJitterRadiusM);

      // CARTO Voyager — more saturated colours than Positron; full street + POI detail (OSM via CARTO)
      var mapInstance = new maplibregl.Map({
        container: 'map',
        style: 'https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json',
        center: [lng, lat],
        zoom: 16,
        attributionControl: true,
      });

      mapInstance.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');

      var markerEl = document.createElement('div');
      markerEl.className = 'map-custom-marker';
      markerEl.setAttribute('role', 'img');
      markerEl.setAttribute('aria-label', contactBusinessName + ' salon location');
      markerEl.innerHTML = [
        '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 34" width="66" height="93" class="block" style="filter:drop-shadow(0 2px 5px rgba(0,0,0,.4))" aria-hidden="true">',
        '<defs>',
        '<linearGradient id="spm-gold" x1="0%" y1="0%" x2="100%" y2="100%">',
        '<stop offset="0%" stop-color="#f4e4a6"/>',
        '<stop offset="28%" stop-color="#d4af37"/>',
        '<stop offset="62%" stop-color="#a67c1f"/>',
        '<stop offset="100%" stop-color="#e8c96b"/>',
        '</linearGradient>',
        '<clipPath id="spm-logo-clip"><circle cx="12" cy="9" r="6.5"/></clipPath>',
        '</defs>',
        '<image href="/assets/logo_256.png" x="5.5" y="2.5" width="13" height="13" clip-path="url(#spm-logo-clip)" preserveAspectRatio="xMidYMid slice"/>',
        '<circle cx="12" cy="9" r="6.5" fill="none" stroke="url(#spm-gold)" stroke-width="1.25"/>',
        '<line x1="12" y1="15.5" x2="12" y2="31.35" stroke="#000000" stroke-width="0.22" stroke-linecap="round"/>',
        '<circle cx="12" cy="32.65" r="1.35" fill="#000000" stroke="url(#spm-gold)" stroke-width="0.35"/>',
        '</svg>',
      ].join('');

      new maplibregl.Marker({ element: markerEl, anchor: 'bottom' })
        .setLngLat([pin.lng, pin.lat])
        .setPopup(
          new maplibregl.Popup({ offset: 50 }).setHTML(
            '<strong>' + contactBusinessName + '</strong><br />' + contactLocationShort
          )
        )
        .addTo(mapInstance);
    });
  </script>
</BaseLayout>
