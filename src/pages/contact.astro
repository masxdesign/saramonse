---
import BaseLayout from '../layouts/BaseLayout.astro';

const hours = [
  { day: 'Mon', time: '10am - 7pm' },
  { day: 'Tues', time: '10am - 7pm' },
  { day: 'Wed', time: '10am - 7pm' },
  { day: 'Thur', time: '10am - 7pm' },
  { day: 'Fri', time: '10am - 7pm' },
  { day: 'Sat', time: '10am - 6pm' },
  { day: 'Sun', time: 'Closed' },
];
---

<BaseLayout
  title="Contact Us | Saramonse Beauty"
  description="Get in touch with Saramonse Beauty — location, hours, and enquiries."
  scrollCompactNav={true}
>
  <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" />

  <!-- Hero title: larger on mobile, ~45% from lg (matches design vs. w-11 / 44px icons) -->
  <section class="py-12 sm:py-16 lg:py-20 px-6 sm:px-8">
    <div class="max-w-5xl mx-auto flex justify-center">
      <h1 class="w-[88%] sm:w-[72%] md:w-[58%] lg:w-[45%] max-w-full shrink-0">
        <img
          src="/assets/get-in-touch-title.svg"
          alt="Get In Touch"
          class="block w-full h-auto mx-auto"
          width="530"
          height="168"
          loading="eager"
          decoding="async"
        />
      </h1>
    </div>
  </section>

  <!-- Form + details -->
  <section class="px-6 sm:px-8 pb-12 sm:pb-16">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 lg:items-start">
      <!-- Contact form -->
      <div>
        <form id="contact-form" class="space-y-10 max-w-md" novalidate>
          <div>
            <label for="contact-name" class="block text-xs font-sans font-normal tracking-wide text-gray-900 mb-2">Name</label>
            <input
              id="contact-name"
              name="name"
              type="text"
              autocomplete="name"
              required
              class="w-full bg-transparent border-0 border-b border-gray-900 pb-2 text-body text-gray-900 font-sans focus:outline-none focus:border-gray-600"
            />
          </div>
          <div>
            <label for="contact-email" class="block text-xs font-sans font-normal tracking-wide text-gray-900 mb-2">Email</label>
            <input
              id="contact-email"
              name="email"
              type="email"
              autocomplete="email"
              required
              class="w-full bg-transparent border-0 border-b border-gray-900 pb-2 text-body text-gray-900 font-sans focus:outline-none focus:border-gray-600"
            />
          </div>
          <div>
            <label for="contact-message" class="block text-xs font-sans font-normal tracking-wide text-gray-900 mb-2">Message</label>
            <textarea
              id="contact-message"
              name="message"
              rows="6"
              required
              class="w-full border border-gray-900 px-3 py-2 text-body text-gray-900 font-sans focus:outline-none focus:ring-1 focus:ring-gray-900 resize-y min-h-[10rem]"
            ></textarea>
          </div>
          <button
            type="submit"
            class="inline-block bg-gray-900 text-white font-sans text-sm tracking-[0.25em] uppercase px-10 py-4 hover:bg-gray-800 transition-colors"
          >
            Submit
          </button>
        </form>
      </div>

      <!-- Business info -->
      <div class="space-y-10 font-sans text-gray-900">
        <div class="flex gap-4">
          <div class="shrink-0 w-11 h-11 rounded-full border border-gray-900 flex items-center justify-center" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <p class="text-body pt-2 leading-relaxed">
            Bermondsey, London (SE1)
          </p>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-11 h-11 rounded-full border border-gray-900 flex items-center justify-center" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
          </div>
          <p class="text-body pt-2">
            <a href="tel:+447773881815" class="hover:underline">0777 388 1815</a>
          </p>
        </div>

        <div class="flex gap-4">
          <div class="shrink-0 w-11 h-11 rounded-full border border-gray-900 flex items-center justify-center" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <p class="text-body pt-2 break-all">
            <a href="mailto:Saramonsebeauty@gmail.com" class="hover:underline">Saramonsebeauty@gmail.com</a>
          </p>
        </div>

        <div class="flex gap-4 items-start">
          <div class="shrink-0 w-11 h-11 rounded-full border border-gray-900 flex items-center justify-center mt-0.5" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-xs font-sans tracking-wide text-gray-900 mb-3">Business hours</p>
            <div class="grid grid-cols-[auto_1fr] gap-x-8 gap-y-2 text-body text-gray-900">
              {hours.map((row) => (
                <>
                  <span class="tabular-nums">{row.day}</span>
                  <span>{row.time}</span>
                </>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="w-full mt-4 sm:mt-8">
    <div id="map" class="w-full h-[min(50vh,28rem)] min-h-[280px] bg-gray-100" role="region" aria-label="Map showing salon location"></div>
  </section>

  <script is:inline src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var form = document.getElementById('contact-form');
      if (form) {
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var name = document.getElementById('contact-name');
          var email = document.getElementById('contact-email');
          var message = document.getElementById('contact-message');
          if (!name || !email || !message) return;
          var body =
            'Name: ' +
            name.value +
            '\n' +
            'Email: ' +
            email.value +
            '\n\n' +
            message.value;
          window.location.href =
            'mailto:Saramonsebeauty@gmail.com?subject=' +
            encodeURIComponent('Contact from ' + (name.value || 'website')) +
            '&body=' +
            encodeURIComponent(body);
        });
      }

      if (typeof maplibregl === 'undefined') return;
      var el = document.getElementById('map');
      if (!el) return;

      // SE1 area — map centroid (OpenStreetMap Nominatim). Marker is jittered for privacy.
      var lat = 51.49594;
      var lng = -0.07714;

      /** Uniform random point within `radiusM` metres of (lat, lng); pin does not show exact address. */
      function jitterLatLng(lat0, lng0, radiusM) {
        var theta = Math.random() * 2 * Math.PI;
        var r = radiusM * Math.sqrt(Math.random());
        var metersEast = r * Math.cos(theta);
        var metersNorth = r * Math.sin(theta);
        var latRad = (lat0 * Math.PI) / 180;
        var metersPerDegLat = 111320;
        var metersPerDegLng = 111320 * Math.cos(latRad);
        return {
          lat: lat0 + metersNorth / metersPerDegLat,
          lng: lng0 + metersEast / metersPerDegLng,
        };
      }

      var pin = jitterLatLng(lat, lng, 100);

      // CARTO Voyager — more saturated colours than Positron; full street + POI detail (OSM via CARTO)
      var map = new maplibregl.Map({
        container: 'map',
        style: 'https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json',
        center: [lng, lat],
        zoom: 16,
        attributionControl: true,
      });

      map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');

      var markerEl = document.createElement('div');
      markerEl.className = 'map-custom-marker';
      markerEl.setAttribute('role', 'img');
      markerEl.setAttribute('aria-label', 'Saramonse Beauty salon location');
      markerEl.innerHTML = [
        '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 34" width="66" height="93" class="block" style="filter:drop-shadow(0 2px 5px rgba(0,0,0,.4))" aria-hidden="true">',
        '<defs>',
        '<linearGradient id="spm-gold" x1="0%" y1="0%" x2="100%" y2="100%">',
        '<stop offset="0%" stop-color="#f4e4a6"/>',
        '<stop offset="28%" stop-color="#d4af37"/>',
        '<stop offset="62%" stop-color="#a67c1f"/>',
        '<stop offset="100%" stop-color="#e8c96b"/>',
        '</linearGradient>',
        '<clipPath id="spm-logo-clip"><circle cx="12" cy="9" r="6.5"/></clipPath>',
        '</defs>',
        '<image href="/assets/logo_256.png" x="5.5" y="2.5" width="13" height="13" clip-path="url(#spm-logo-clip)" preserveAspectRatio="xMidYMid slice"/>',
        '<circle cx="12" cy="9" r="6.5" fill="none" stroke="url(#spm-gold)" stroke-width="1.25"/>',
        '<line x1="12" y1="15.5" x2="12" y2="31.35" stroke="#000000" stroke-width="0.22" stroke-linecap="round"/>',
        '<circle cx="12" cy="32.65" r="1.35" fill="#000000" stroke="url(#spm-gold)" stroke-width="0.35"/>',
        '</svg>',
      ].join('');

      new maplibregl.Marker({ element: markerEl, anchor: 'bottom' })
        .setLngLat([pin.lng, pin.lat])
        .setPopup(
          new maplibregl.Popup({ offset: 50 }).setHTML(
            '<strong>Saramonse Beauty</strong><br />Bermondsey, London (SE1)'
          )
        )
        .addTo(map);
    });
  </script>
</BaseLayout>
