---
import HeroLayout from '../layouts/HeroLayout.astro';
import GiftVouchersSection from '../components/GiftVouchersSection.astro';
import InstagramSection from '../components/InstagramSection.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import { homeFaqItems } from '../data/faq-content.js';
import contact from '../data/contact.json';
import { FRESHA_BOOKING_URL } from '../data/site-urls.js';

const { location } = contact;
---
<HeroLayout
  title="Saramonse Beauty | Premium Beauty Therapy"
  description="Saramonse Beauty - Premium beauty therapy services"
  isHomepage={true}
>
<!-- Hero Section -->
<section class="relative min-h-screen flex flex-col" id="home">
    <!-- Background Video with Dark Overlay -->
    <div class="absolute inset-0 z-0">
        <video
            class="w-full h-full object-cover object-center"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="/assets/home4-hero-poster.webp"
            aria-label="Saramonse Beauty - Beauty therapy hero video"
        >
            <source src="/assets/home4-hero.small.webm" type="video/webm" />
            <source src="/assets/home4-hero.small.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-black/20"></div>
        <!-- Mobile-only: extra gradient so hero copy reads clearly over the video -->
        <div
          class="pointer-events-none absolute inset-0 z-[1] bg-gradient-to-t from-black/65 via-black/40 to-transparent md:hidden"
          aria-hidden="true"
        >
        </div>
    </div>

    <!-- Hero Content -->
    <div class="flex-1 flex flex-col justify-center relative z-10 pt-32">
        <div class="max-w-xl px-8 max-md:translate-y-[8vh] md:translate-y-0 md:pl-16 lg:pl-24">
            <h1 class="text-4xl md:text-5xl text-white mb-4 leading-tight tracking-wide uppercase font-light text-shadow-hero" style="font-family: 'Cormorant Garamond', 'Georgia', serif;">Facials Designed<br>To Refresh &<br>Renew</h1>
            <div class="mb-8">
                <p class="text-body-hero text-white/90 font-sans font-light leading-relaxed mb-2">Get glowing with our tailored Facials at Sara Monse. Designed for instant and long-lasting results.</p>
                <p class="text-body-hero text-pink-400 font-sans italic">Book your glow-up today!</p>
            </div>
            <a
              href={FRESHA_BOOKING_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-10 py-4 bg-gradient-to-r from-orange-400 to-pink-500 text-white font-sans font-semibold tracking-widest uppercase text-sm hover:shadow-2xl transition-all w-fit">Book Now</a>
        </div>
    </div>
</section>

<!-- Your Wellbeing, Our Mission Section -->
<section class="py-24 px-8 bg-white" id="about">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <!-- Image Grid -->
        <div class="grid grid-cols-2 gap-4">
            <!-- Large Image - Spans 2 rows -->
            <div class="col-span-2 w-full h-96 bg-beauty-light overflow-hidden">
                <img src="/assets/main-treatment.webp" alt="Facial treatment at Saramonse Beauty" class="w-full h-full object-cover">
            </div>
            <!-- Small Image 1 -->
            <div class="w-full h-48 bg-beauty-light overflow-hidden">
                <img src="/assets/salon-room.webp" alt="Saramonse Beauty salon interior" class="w-full h-full object-cover">
            </div>
            <!-- Small Image 2 -->
            <div class="w-full h-48 bg-beauty-light overflow-hidden">
                <img src="/assets/massage.webp" alt="Massage treatment at Saramonse Beauty" class="w-full h-full object-cover">
            </div>
        </div>

        <!-- Content -->
        <div class="space-y-8">
            <h2 class="text-4xl md:text-5xl text-gray-900 font-light tracking-wide uppercase leading-tight" style="font-family: 'Cormorant Garamond', 'Georgia', serif;">
                Your Wellbeing, Our Mission
            </h2>

            <div class="space-y-6">
                <p class="text-body text-gray-700 font-sans leading-relaxed">
                    {location.indexParagraph1}
                </p>

                <p class="text-body text-gray-700 font-sans leading-relaxed">
                    {location.indexParagraph2}
                </p>
            </div>

            <a
              href={FRESHA_BOOKING_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-10 py-4 bg-gradient-to-r from-orange-400 to-pink-500 text-white font-sans font-semibold tracking-widest uppercase text-sm hover:shadow-2xl transition-all">
                Book Now
            </a>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="bg-white" id="services">
    <!-- Facials -->
    <div class="flex flex-col lg:flex-row">
        <!-- Image -->
        <div class="w-full lg:w-1/2 h-80 sm:h-96 lg:h-auto bg-beauty-light overflow-hidden order-1">
            <img src="/assets/facials-service.webp" alt="Facial treatment" class="w-full h-full object-cover">
        </div>
        <!-- Content -->
        <div class="w-full lg:w-1/2 flex flex-col justify-center px-6 py-12 sm:p-12 lg:p-16 bg-[#f8f6f3] order-2">
            <h3 class="text-2xl sm:text-3xl lg:text-4xl text-gray-900 font-light mb-4 sm:mb-6" style="font-family: 'Cormorant Garamond', 'Georgia', serif;">Facials</h3>
            <p class="text-body-card text-gray-700 font-sans leading-relaxed mb-6 sm:mb-8">
                Personalised treatments that go beyond skin deep, blending care, artistry, and renewal.
            </p>
            <a href="/services/facials/" class="inline-block px-8 sm:px-10 py-3 border-2 border-gray-900 text-gray-900 font-sans text-xs sm:text-sm tracking-wider uppercase hover:bg-gray-900 hover:text-white transition-all w-fit">
                Explore facials
            </a>
        </div>
    </div>

    <!-- Body -->
    <div class="flex flex-col lg:flex-row-reverse">
        <!-- Image -->
        <div class="w-full lg:w-1/2 h-80 sm:h-96 lg:h-auto bg-beauty-light overflow-hidden order-1">
            <img src="/assets/body-service.webp" alt="Body massage treatment" class="w-full h-full object-cover">
        </div>
        <!-- Content -->
        <div class="w-full lg:w-1/2 flex flex-col justify-center px-6 py-12 sm:p-12 lg:p-16 bg-white order-2">
            <h3 class="text-2xl sm:text-3xl lg:text-4xl text-gray-900 font-light mb-4 sm:mb-6" style="font-family: 'Cormorant Garamond', 'Georgia', serif;">Body</h3>
            <p class="text-body-card text-gray-700 font-sans leading-relaxed mb-6 sm:mb-8">
                Rebalance body and mind with treatments designed to release tension and restore harmony.
            </p>
            <a href="/services/body/" class="inline-block px-8 sm:px-10 py-3 border-2 border-gray-900 text-gray-900 font-sans text-xs sm:text-sm tracking-wider uppercase hover:bg-gray-900 hover:text-white transition-all w-fit">
                Discover body treatments
            </a>
        </div>
    </div>
</section>

<!-- Additional Services Grid Section -->
<section class="py-16 sm:py-20 lg:py-24 px-6 sm:px-8 bg-[#f8f6f3]">
    <div class="max-w-7xl mx-auto">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
            <!-- Injectables -->
            <div class="flex flex-col">
                <!-- Image -->
                <div class="w-full h-64 sm:h-72 lg:h-80 bg-beauty-light overflow-hidden mb-6">
                    <img src="/assets/injectables-service.webp" alt="Injectable treatments" class="w-full h-full object-cover">
                </div>
                <!-- Content -->
                <h3 class="text-2xl sm:text-3xl text-gray-900 font-light mb-4" style="font-family: 'Cormorant Garamond', 'Georgia', serif;">Injectables</h3>
                <p class="text-body-card text-gray-700 font-sans leading-relaxed mb-6 flex-grow">
                    Advanced treatments designed to revitalise, refine, and restore confidence.
                </p>
                <a href="/services/injectables/" class="inline-block px-8 sm:px-10 py-3 border-2 border-gray-900 text-gray-900 font-sans text-xs sm:text-sm tracking-wider uppercase hover:bg-gray-900 hover:text-white transition-all w-fit">
                    Explore injectables
                </a>
            </div>

            <!-- Eyes -->
            <div class="flex flex-col">
                <!-- Image -->
                <div class="w-full h-64 sm:h-72 lg:h-80 bg-beauty-light overflow-hidden mb-6">
                    <img src="/assets/eyes-service.webp" alt="Eye treatments" class="w-full h-full object-cover">
                </div>
                <!-- Content -->
                <h3 class="text-2xl sm:text-3xl text-gray-900 font-light mb-4" style="font-family: 'Cormorant Garamond', 'Georgia', serif;">Eyes</h3>
                <p class="text-body-card text-gray-700 font-sans leading-relaxed mb-6 flex-grow">
                    Frame your beauty with expert shaping that brings depth and definition to your gaze.
                </p>
                <a href="/services/eyes/" class="inline-block px-8 sm:px-10 py-3 border-2 border-gray-900 text-gray-900 font-sans text-xs sm:text-sm tracking-wider uppercase hover:bg-gray-900 hover:text-white transition-all w-fit">
                    Explore eyes
                </a>
            </div>

            <!-- Nails -->
            <div class="flex flex-col">
                <!-- Image -->
                <div class="w-full h-64 sm:h-72 lg:h-80 bg-beauty-light overflow-hidden mb-6">
                    <img src="/assets/nails-service.webp" alt="Nail treatments" class="w-full h-full object-cover">
                </div>
                <!-- Content -->
                <h3 class="text-2xl sm:text-3xl text-gray-900 font-light mb-4" style="font-family: 'Cormorant Garamond', 'Georgia', serif;">Nails</h3>
                <p class="text-body-card text-gray-700 font-sans leading-relaxed mb-6 flex-grow">
                    From timeless elegance to modern artistry, every manicure is a statement of care and style.
                </p>
                <a href="/services/nails/" class="inline-block px-8 sm:px-10 py-3 border-2 border-gray-900 text-gray-900 font-sans text-xs sm:text-sm tracking-wider uppercase hover:bg-gray-900 hover:text-white transition-all w-fit">
                    Explore nails
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Reviews & Testimonials Section -->
<section class="pt-16 sm:pt-20 lg:pt-24 pb-6 sm:pb-8 lg:pb-10 px-6 sm:px-8 bg-white">
    <div class="max-w-7xl mx-auto">
        <!-- Section Title -->
        <h2 class="text-2xl sm:text-3xl lg:text-4xl text-center text-gray-900 font-light mb-12 sm:mb-16 lg:mb-20 tracking-wide uppercase" style="font-family: 'Cormorant Garamond', 'Georgia', serif;">
            Reviews & Testimonials
        </h2>

        <!-- Carousel Container -->
        <div class="relative">
            <!-- Splide Slider -->
            <div id="reviews-splide" class="splide">
                <div class="splide__track">
                    <ul class="splide__list">
                        <!-- Review Card 1 -->
                        <li class="splide__slide py-3 px-5 sm:px-8 sm:py-4">
                            <div class="review-card-inner bg-white p-8 sm:p-10 h-full flex flex-col">
                                <h3 class="text-body font-medium text-gray-900 mb-3 font-sans">Alejandra Espinosa</h3>
                                <div class="flex gap-1 mb-4">
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                </div>
                                <p class="text-body text-gray-700 font-sans leading-relaxed">
                                    I recently purchased the wireless earbuds from this store, and they exceeded all my expectations with their superb sound quality and comfortable fit. The customer service was also outstanding, making my shopping experience truly enjoyable.
                                </p>
                            </div>
                        </li>
                        <!-- Review Card 2 -->
                        <li class="splide__slide py-3 px-5 sm:px-8 sm:py-4">
                            <div class="review-card-inner bg-white p-8 sm:p-10 h-full flex flex-col">
                                <h3 class="text-body font-medium text-gray-900 mb-3 font-sans">Fabiola Mendoza</h3>
                                <div class="flex gap-1 mb-4">
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                </div>
                                <p class="text-body text-gray-700 font-sans leading-relaxed">
                                    I recently purchased the wireless earbuds from this store, and they exceeded all my expectations with their superb sound quality and comfortable fit. The customer service was also outstanding, making my shopping experience truly enjoyable.
                                </p>
                            </div>
                        </li>
                        <!-- Review Card 3 -->
                        <li class="splide__slide py-3 px-5 sm:px-8 sm:py-4">
                            <div class="review-card-inner bg-white p-8 sm:p-10 h-full flex flex-col">
                                <h3 class="text-body font-medium text-gray-900 mb-3 font-sans">Glenda Quintero</h3>
                                <div class="flex gap-1 mb-4">
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                    <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
                                </div>
                                <p class="text-body text-gray-700 font-sans leading-relaxed">
                                    I recently purchased the wireless earbuds from this store, and they exceeded all my expectations with their superb sound quality and comfortable fit. The customer service was also outstanding, making my shopping experience truly enjoyable.
                                </p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Navigation Arrows -->
            <button id="prev-btn" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 sm:-translate-x-6 lg:-translate-x-12 w-12 h-12 flex items-center justify-center text-gray-400 hover:text-gray-900 transition-colors">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
            </button>
            <button id="next-btn" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 sm:translate-x-6 lg:translate-x-12 w-12 h-12 flex items-center justify-center text-gray-400 hover:text-gray-900 transition-colors">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
            </button>
        </div>

        <!-- Carousel Indicators (square dots) -->
        <div class="flex justify-center gap-3 mt-8 sm:mt-10">
            <button class="indicator w-3 h-3 bg-gray-900 hover:bg-gray-700 transition-colors" data-index="0"></button>
            <button class="indicator w-3 h-3 bg-gray-300 hover:bg-gray-400 transition-colors" data-index="1"></button>
            <button class="indicator w-3 h-3 bg-gray-300 hover:bg-gray-400 transition-colors" data-index="2"></button>
        </div>
    </div>

    <script>
      import Splide from '@splidejs/splide';
      import '@splidejs/splide/dist/css/splide-core.min.css';

      const reviewInnerCards = document.querySelectorAll('.review-card-inner');
      const reviewIndicators = document.querySelectorAll('.indicator');

      const reviewsSplide = new Splide('#reviews-splide', {
        type: 'loop',
        perPage: 3,
        perMove: 1,
        arrows: false,
        pagination: false,
        speed: 500,
        easing: 'ease-in-out',
        drag: true,
        breakpoints: {
          1023: { perPage: 2 },
          639: { perPage: 1 },
        },
      });

      function updateActive(index: number) {
        reviewInnerCards.forEach((card, i) => {
          if (i === index) {
            (card as HTMLElement).style.border = '2px solid transparent';
            (card as HTMLElement).style.borderImage =
              'linear-gradient(to bottom right, #fb923c, #ec4899) 1';
            (card as HTMLElement).style.boxShadow =
              '0 2px 8px rgba(0, 0, 0, 0.06), 0 8px 20px rgba(0, 0, 0, 0.1)';
          } else {
            (card as HTMLElement).style.border = '';
            (card as HTMLElement).style.borderImage = '';
            (card as HTMLElement).style.boxShadow = '';
          }
        });

        reviewIndicators.forEach((dot, i) => {
          dot.classList.toggle('bg-gray-900', i === index);
          dot.classList.toggle('bg-gray-300', i !== index);
        });
      }

      reviewsSplide.on('moved', (newIndex: number) => {
        updateActive(newIndex);
      });

      reviewsSplide.mount();
      updateActive(0);

      document.getElementById('prev-btn')?.addEventListener('click', () => {
        reviewsSplide.go('<');
      });

      document.getElementById('next-btn')?.addEventListener('click', () => {
        reviewsSplide.go('>');
      });

      reviewIndicators.forEach((dot) => {
        dot.addEventListener('click', () => {
          const idx = dot.dataset.index;
          if (idx !== undefined) reviewsSplide.go(parseInt(idx, 10));
        });
      });
    </script>
</section>

<FaqAccordion
  heading="Questions"
  intro="A few things first-time visitors often ask about Sara Monse Beauty."
  items={homeFaqItems}
  defaultOpenCount={1}
  class="bg-[#f8f6f3] !pt-8 sm:!pt-10 lg:!pt-12"
/>

<GiftVouchersSection />
<InstagramSection />
</HeroLayout>
