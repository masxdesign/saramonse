---
import VideoHeroLayout from '../../layouts/VideoHeroLayout.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import { serviceFaqs } from '../../data/faq-content.js';
---

<VideoHeroLayout
  title="Injectables | Saramonse Beauty"
  description="Injectable treatments at Saramonse Beauty - refined, rejuvenating results with advanced techniques"
  videoWebmSrc="/assets/injectables-hero.small.webm?t=1"
  videoMp4Src="/assets/injectables-hero.small.mp4?t=1"
  videoPoster="/assets/injectables-hero-poster.jpg"
  footerTheme="dark"
>
  <!-- Intro -->
  <section class="py-16 sm:py-20 lg:py-24 px-6 sm:px-8">
    <div class="max-w-4xl mx-auto">
      <h2
        class="text-4xl sm:text-5xl lg:text-6xl text-gray-900 font-light tracking-[0.3em] uppercase mb-6"
        style="font-family: 'Cormorant Garamond', 'Georgia', serif;"
      >
        Injectables
      </h2>

      <p class="text-body-intro text-gray-700 font-sans leading-relaxed max-w-3xl mb-10">
        Targeted injectable treatments designed to refine, rejuvenate and restore; delivering natural results with
        advanced techniques.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="/#book"
          class="inline-block bg-gradient-to-r from-amber-400 via-orange-400 to-pink-500 text-white font-sans text-sm tracking-[0.2em] uppercase px-8 py-4 hover:opacity-90 transition-opacity"
          >Book Treatment</a
        >
        <a
          href="#gift-vouchers"
          class="inline-block border border-pink-400 text-pink-400 font-sans text-sm tracking-[0.2em] uppercase px-8 py-4 hover:bg-pink-400 hover:text-white transition-colors"
          >Buy Gift Vouchers</a
        >
      </div>
    </div>
  </section>

  <!-- Fat Dissolve Injections -->
  <section class="px-6 sm:px-8 pt-16 sm:pt-20 lg:pt-24 pb-20 sm:pb-24 lg:pb-28">
    <div class="max-w-4xl mx-auto">
      <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 font-sans tracking-tight mb-8 sm:mb-10">
        Fat Dissolve Injections
      </h3>

      <p class="text-body text-gray-900 font-sans font-normal leading-relaxed mb-12 sm:mb-14 lg:mb-16 max-w-3xl">
        Our Fat Dissolve Injections target stubborn pockets of fat that don&rsquo;t shift with diet or exercise. Using a
        safe, effective solution, the treatment breaks down fat cells which are then naturally eliminated by the body.
      </p>

      <p class="text-body text-gray-900 font-sans font-normal underline underline-offset-[5px] decoration-1 mb-8 sm:mb-10">
        We Offer Treatments for:
      </p>

      <div class="space-y-6 sm:space-y-7">
        <div class="flex justify-between items-baseline gap-x-6">
          <p class="text-body text-gray-900 font-sans font-normal leading-relaxed min-w-0 flex-1 pr-2">
            <span class="font-bold">Cheeks</span> - to slim and contour the face
          </p>
          <div class="shrink-0 w-44 flex justify-end">
            <span class="inline-flex items-baseline gap-1.5 font-sans text-gray-900">
              <span class="text-sm font-normal">From</span>
              <span class="text-lg sm:text-xl font-bold tabular-nums">&pound;150</span>
            </span>
          </div>
        </div>

        <div class="flex justify-between items-baseline gap-x-6">
          <p class="text-body text-gray-900 font-sans font-normal leading-relaxed min-w-0 flex-1 pr-2">
            <span class="font-bold">Chin</span> - to reduce the appearance of a double chin
          </p>
          <div class="shrink-0 w-44 flex justify-end">
            <span class="inline-flex items-baseline gap-1.5 font-sans text-gray-900">
              <span class="text-sm font-normal">From</span>
              <span class="text-lg sm:text-xl font-bold tabular-nums">&pound;150</span>
            </span>
          </div>
        </div>

        <div class="flex justify-between items-baseline gap-x-6">
          <p class="text-body text-gray-900 font-sans font-normal leading-relaxed min-w-0 flex-1 pr-2">
            <span class="font-bold">Abdomen</span> - to smooth and flatten the tummy area
          </p>
          <div class="shrink-0 w-44 flex justify-end">
            <span class="inline-flex items-baseline gap-1.5 font-sans text-gray-900">
              <span class="text-sm font-normal">From</span>
              <span class="text-lg sm:text-xl font-bold tabular-nums">&pound;180</span>
            </span>
          </div>
        </div>
      </div>

      <p class="text-body text-gray-900 font-sans font-normal leading-relaxed mt-14 sm:mt-16 lg:mt-20 max-w-3xl">
        (Results are gradual, with best outcomes achieved over a course of sessions.)
      </p>
    </div>
  </section>

  <!-- Vitamin B12 & Profhilo (same treatment format as Facials) -->
  <section class="px-6 sm:px-8 pt-16 sm:pt-20 lg:pt-24 pb-16 sm:pb-20 lg:pb-24">
    <div class="max-w-4xl mx-auto divide-y divide-gray-200">
      <div class="py-10 sm:py-12">
        <div class="flex justify-between items-baseline mb-4">
          <h3 class="text-lg sm:text-xl font-semibold text-gray-900 font-sans">Vitamin B12</h3>
          <span class="text-lg sm:text-xl text-gray-900 font-sans shrink-0 ml-4">&pound;27</span>
        </div>
        <p class="text-body text-gray-700 font-sans leading-relaxed">
          Boost your energy, focus, and overall wellbeing with a quick Vitamin B12 injection. This essential nutrient
          supports the immune system, reduces fatigue, and helps improve mood and metabolism. (20mins)
        </p>
      </div>

      <div class="py-10 sm:py-12">
        <div class="flex justify-between items-baseline mb-4">
          <h3 class="text-lg sm:text-xl font-semibold text-gray-900 font-sans">Profhilo (Skin Boosters)</h3>
          <span class="text-lg sm:text-xl text-gray-900 font-sans shrink-0 ml-4">&pound;200</span>
        </div>
        <p class="text-body text-gray-700 font-sans leading-relaxed">
          An injectable skin booster containing high concentrations of hyaluronic acid. Profhilo&reg; works beneath the skin
          to hydrate, improve elasticity, and stimulate collagen and elastin, leaving skin firmer, smoother, and more
          radiant. (45mins)
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pt-4 sm:pt-6 pb-16 sm:pb-20 lg:pb-24 px-6 sm:px-8">
    <div class="max-w-4xl mx-auto flex flex-wrap gap-6">
      <a
        href="/#book"
        class="inline-block bg-gradient-to-r from-amber-400 via-orange-400 to-pink-500 text-white font-sans text-sm tracking-[0.2em] uppercase px-10 py-5 hover:opacity-90 transition-opacity"
        >Book Treatment</a
      >
      <a
        href="/assets/injectables-menu.pdf"
        target="_blank"
        class="inline-block border border-pink-400 text-pink-400 font-sans text-sm tracking-[0.2em] uppercase px-10 py-5 hover:bg-pink-400 hover:text-white transition-colors"
        >Download Menu</a
      >
    </div>
  </section>

  <FaqAccordion
    heading="Common questions"
    items={serviceFaqs.injectables}
    defaultOpenCount={0}
    class="bg-[#f8f6f3] !pt-4 sm:!pt-6 lg:!pt-8"
  />
</VideoHeroLayout>
